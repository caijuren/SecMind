# === SecMind Backend Configuration ===
# Copy this file to .env and fill in your values

# --- Database ---
DATABASE_URL=postgresql://secmind:your_secure_password_here@postgres:5432/secmind
POSTGRES_USER=secmind
POSTGRES_PASSWORD=change_me_to_a_strong_random_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=secmind

# --- Security (MUST change before production!) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-string-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
