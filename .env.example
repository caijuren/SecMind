APP_VERSION=2.3.0

# 避开服务器现有服务端口
FRONTEND_PORT=3002
BACKEND_PORT=8001

# 如果你直接用 IP 访问，请保持下面两个地址一致
NEXT_PUBLIC_API_BASE_URL=http://124.220.103.120:8001/api/v1
NEXT_PUBLIC_API_URL=http://124.220.103.120:8001/api/v1

# 后端允许前端跨域访问
CORS_ORIGINS=http://124.220.103.120:3002

# 数据库 / 缓存
POSTGRES_PASSWORD=change-this-postgres-password
REDIS_PASSWORD=change-this-redis-password

# JWT 密钥，必须改成随机高强度字符串
SECRET_KEY=change-this-secret-key

# 可选 AI 配置
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
