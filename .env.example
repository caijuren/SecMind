# SecMind 生产环境配置
# 复制此文件为 .env 并修改配置

# Docker 镜像仓库
DOCKER_USERNAME=your_dockerhub_username

# 数据库密码（首次部署后请勿修改）
POSTGRES_PASSWORD=your_strong_password_here

# JWT 密钥（首次部署后请勿修改）
SECRET_KEY=your_random_secret_key_here

# 端口配置（如被占用请修改）
FRONTEND_PORT=3000
BACKEND_PORT=8000

# 部署版本（通常由 deploy.sh 自动管理）
# APP_VERSION=latest